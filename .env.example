# Discord Bot Token (required)
# Get yours at: https://discord.com/developers/applications
BOT_TOKEN=your_discord_bot_token_here

# Development Guild ID (optional)
# Set this for instant slash command registration during development
# Leave empty for global registration (takes ~1 hour to propagate)
DEV_GUILD_ID=

# v1.0 Migration (optional — only needed when migrating from v1)
# V1_GUILD_ID=
# V1_TARGET_TAG=
# V1_TAG_ROLE_ID=
# V1_LOG_CHANNEL_ID=
